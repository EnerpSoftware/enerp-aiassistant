[Unit]
Description=Asystentka TTS Server (FastAPI + edge-tts)
After=network.target

[Service]
Type=simple
User=rancher
WorkingDirectory=/home/rancher/assistant-web
Environment=PATH=/home/rancher/assistant-web/venv/bin:/usr/bin:/bin
ExecStart=/home/rancher/assistant-web/venv/bin/uvicorn server:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
